# ==========================================
# VAATHI — Environment Configuration
# ==========================================

# ---- DATABASE ----
# Option 1: Local SQLite (default, for development)
DATABASE_URL=file:./db/dev.db

# Option 2: Turso (for Vercel deployment)
# Create a free database at https://turso.tech
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
# DIRECT_URL=libsql://your-db-name-your-org.turso.io

# Turso-specific (if using Turso)
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-auth-token
