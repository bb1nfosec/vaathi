generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  language      String   @default("english")
  llmProvider   String   @default("groq")
  llmApiKey     String   @default("")
  llmModel      String   @default("llama-3.3-70b-versatile")
  llmBaseUrl    String   @default("")
  tier          String   @default("egg")
  xp            Int      @default(0)
  level         Int      @default(1)
  streak        Int      @default(0)
  lastActive    DateTime @default(now())
  topicProgress String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  chatMessages  ChatMessage[]
  completedLabs CompletedLab[]
  completedCTFs CompletedCTF[]
  badges        UserBadge[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  language  String   @default("english")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompletedLab {
  id           String   @id @default(cuid())
  userId       String
  labTitle     String
  difficulty   String   @default("")
  xpEarned     Int      @default(0)
  hintsUsed    Int      @default(0)
  completedAt  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CompletedCTF {
  id           String   @id @default(cuid())
  userId       String
  challengeTitle String
  category     String   @default("")
  difficulty   String   @default("")
  pointsEarned Int      @default(0)
  completedAt  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  name      String
  emoji     String   @default("🏅")
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
