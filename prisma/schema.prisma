generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String   @default("Hacker")
  tier         String   @default("egg")
  xp           Int      @default(0)
  level        Int      @default(1)
  streak       Int      @default(0)
  college      String   @default("")
  state        String   @default("")
  skills       String   @default("{}")
  badges       String   @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  completedLabs  CompletedLab[]
  completedCTFs  CompletedCTF[]
  chatMessages   ChatMessage[]
}

model Lab {
  id          String @id @default(cuid())
  title       String
  description String
  category    String
  difficulty  String
  duration    Int
  xpReward    Int
  flag        String
  steps       String
  hints       String   @default("[]")
  createdAt   DateTime @default(now())
}

model CompletedLab {
  id           String   @id @default(cuid())
  userId       String
  labId        String
  xpEarned     Int
  hintsUsed    Int      @default(0)
  stepsCompleted Int    @default(0)
  completedAt  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CTFChallenge {
  id          String   @id @default(cuid())
  title       String
  description String
  difficulty  String
  points      Int
  flag        String
  category    String
  participants Int     @default(0)
  timeRemaining String @default("")
  createdAt   DateTime @default(now())
}

model CompletedCTF {
  id           String   @id @default(cuid())
  userId       String
  challengeId  String
  pointsEarned Int
  completedAt  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  language  String   @default("english")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
